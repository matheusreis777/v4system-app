  {
    "expo": {
      "name": "ConnectCar System",
      "slug": "v4system-app",
      "scheme": "v4system",
      "version": "1.0.0",
      "orientation": "portrait",
      "icon": "./assets/icon.png",
      "userInterfaceStyle": "light",
      "newArchEnabled": true,
      "splash": {
        "image": "./assets/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#061D3D"
      },
      "ios": {
        "supportsTablet": true,
        "bundleIdentifier": "com.v4system.crm"
      },
      "android": {
        "package": "com.v4system.crm",
        "adaptiveIcon": {
          "foregroundImage": "./assets/icon.png",
          "backgroundColor": "#061D3D"
        },
        "statusBar": {
          "backgroundColor": "#061D3D",
          "statusBarStyle": "light-content"
        },
        "navigationBar": {
          "backgroundColor": "#061D3D",
          "buttonColor": "light"
        },
        "googleServicesFile": "./google-services.json",
        "edgeToEdgeEnabled": true,
        "softwareKeyboardLayoutMode": "pan",
        "permissions": [
          "INTERNET"
        ]
      },
      "plugins": [
        "expo-notifications",
        "expo-secure-store",
        "expo-font",
        "expo-router"
      ],
      "extra": {
        "eas": {
          "projectId": "5d4fd711-b2ad-4bf8-9a9f-78303b0a92b8"
        }
      }
    }
  }