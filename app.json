  {
    "expo": {
      "name": "V4 System",
      "slug": "v4system-app",
      "scheme": "v4system",
      "version": "1.0.0",
      "orientation": "portrait",
      "icon": "./assets/icon.png",
      "userInterfaceStyle": "light",
      "newArchEnabled": true,
      "splash": {
        "image": "./assets/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#ffffff"
      },
      "ios": {
        "supportsTablet": true,
        "bundleIdentifier": "com.v4system.crm",
        // add the path to your GoogleService-Info.plist if you use FCM / analytics
        // this file is generated on the Firebase console and should be placed at
        // the project root.
        "googleServicesFile": "./GoogleService-Info.plist"
      },
      "android": {
        "package": "com.v4system.crm",
        "adaptiveIcon": {
          "foregroundImage": "./assets/adaptive-icon.png",
          "backgroundColor": "#ffffff"
        },
        "edgeToEdgeEnabled": true,
        "softwareKeyboardLayoutMode": "resize",
        "permissions": ["INTERNET"],
        "usesCleartextTraffic": true,
        // path to your Firebase config file for Android. Create this in the project root and
        // update the string below (see expo docs for details).
        "googleServicesFile": "./google-services.json"
      },
      "plugins": [
        // the notifications plugin wires native configuration automatically when you
        // prebuild / build the app. keep it near the top of the array.
        "expo-notifications",
        "expo-secure-store",
        "expo-font",
        "expo-router"
      ],
      "extra": {
        "eas": {
          "projectId": "5d4fd711-b2ad-4bf8-9a9f-78303b0a92b8"
        }
      }
    }
  }
